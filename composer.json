{
  "name": "industrialdev/wicket-wp-memberships",
  "description": "Wicket Memberships",
  "version": "1.0.111",
  "keywords": ["wordpress", "plugin"],
  "homepage": "https://github.com/industrialdev/wicket-wp-memberships",
  "authors": [
    {
      "name": "Wicket",
      "homepage": "https://wicket.io"
    }
  ],
  "type": "wordpress-plugin",
  "autoload": {
    "psr-4": {
      "Wicket_Memberships\\": "includes/"
    }
  },
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^8",
    "yoast/phpunit-polyfills": "^4.0"
  },
  "scripts": {
    "version-bump": "@php ./.ci/version-bump.php"
  },
  "scripts-descriptions": {
    "version-bump": "Bump the plugin version in composer.json and the main plugin file. Pass patch|minor|major or an explicit X.Y.Z."
  }
}
